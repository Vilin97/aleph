theorem glAction_commutes_symAction {R : Type*} [Field R]
    {M : Type*} [AddCommGroup M] [Module R M]
    {k : ℕ} (g : (M →ₗ[R] M)ˣ) (σ : Equiv.Perm (Fin k)) :
    Commute (glAction R M k g) (symAction R M k σ) := by
  ext x
  simpa [glAction, symAction] using PiTensorProduct.map_comp_reindex_eq (R := R) (s := fun _ : Fin k => M) (t := fun _ : Fin k => M) (fun _ => (g : M →ₗ[R] M)) σ

theorem glAction_adjoin_le_centralizer_symAction {R : Type*} [Field R]
    {M : Type*} [AddCommGroup M] [Module R M]
    {k : ℕ} :
    Algebra.adjoin R (Set.range (glAction R M k)) ≤
      Subalgebra.centralizer R (Set.range (symAction R M k)) := by
  refine Algebra.adjoin_le ?_
  rintro _ ⟨g, rfl⟩
  change glAction R M k g ∈ Subalgebra.centralizer R (Set.range (symAction R M k))
  rw [Subalgebra.mem_centralizer_iff]
  intro y hy
  rcases hy with ⟨σ, rfl⟩
  exact (glAction_commutes_symAction (R := R) (M := M) (k := k) g σ).eq.symm

theorem symmetrized_basisEnd_mem_adjoin_diagonal_units {R : Type*} [Field R]
    {M : Type*} [AddCommGroup M] [Module R M] [FiniteDimensional R M]
    {k : ℕ} [Invertible (k.factorial : R)]
    (a b : Fin k → Fin (Module.finrank R M)) :
    (∑ σ : Equiv.Perm (Fin k),
      PiTensorProduct.tprod R (fun i : Fin k =>
        Module.Basis.end (Module.finBasis R M) (a (σ i), b (σ i)))) ∈
      Algebra.adjoin R
        (Set.range fun g : (M →ₗ[R] M)ˣ =>
          PiTensorProduct.tprod R (fun _ : Fin k => (g : Module.End R M))) := by
  -- This is the real matrix-unit / transvection core of the Schur–Weyl argument. Let
  -- `e := Module.finBasis R M` and write
  -- `E i j := Module.Basis.end e (i, j)`.
  -- We must show that the orbit sum of the basis-endomorphism tensor
  -- `∑ σ, ⨂ₜ E (a (σ i)) (b (σ i))`
  -- lies in the subalgebra generated by the diagonal unit tensors `δ(g) := PiTensorProduct.tprod R (fun _ => (g : Module.End R M))`.
  -- 
  -- Recommended proof split:
  -- 1. **Off-diagonal matrix units (`i ≠ j`)**
  --    * Use transvections `u_{ij}(c) := 1 + c • E i j`.
  --    * Since `(E i j)^2 = 0` for `i ≠ j`, these are units with inverse `1 - c • E i j`.
  --    * Therefore every `δ(u_{ij}(c))` lies in the generating set.
  --    * Expanding `δ(u_{ij}(c))` as a polynomial in `c` produces orbit sums of tensors built from the off-diagonal `E i j`.
  --    * Use interpolation / Vandermonde with `k+1` distinct scalars `c` to isolate the desired coefficient. The assumption `[Invertible (k.factorial : R)]` guarantees `char R = 0` or `char R > k`, hence enough distinct scalars are available.
  -- 
  -- 2. **Diagonal matrix units (`i = j`)**
  --    * Use diagonal scaling automorphisms coming from `e.unitsSMul w` (equivalently, automorphisms acting by a chosen unit scalar on one basis vector and by `1` on the others).
  --    * Their diagonal tensors `δ(g_w)` again lie in the generating set.
  --    * Expanding these diagonal tensors gives polynomial expressions in the orbit sums of diagonal matrix units.
  --    * Use the same interpolation idea to isolate the required monomial-symmetric/orbit-sum term.
  -- 
  -- 3. **Mixed families**
  --    * Combine the off-diagonal and diagonal constructions multiplicatively inside the subalgebra.
  --    * If this is cleaner after transport to matrices, use `algEquivMatrix (Module.finBasis R M)` and prove the matrix version first; then transport back via `PiTensorProduct.congr`.
  -- 
  -- Useful declarations to search/use:
  -- * `Module.Basis.end`
  -- * `Module.Basis.unitsSMul` / `Module.Basis.isUnitSMul`
  -- * matrix transvection API (`Matrix.TransvectionStruct`, `Matrix.Pivot...`) if you decide to transport to matrices
  -- * `algEquivMatrix (Module.finBasis R M)`
  -- 
  -- This node should contain the genuinely hard algebraic construction. Everything else above it should become bookkeeping.
  sorry

theorem diagonal_tprod_mem_adjoin_diagonal_units {R : Type*} [Field R]
    {M : Type*} [AddCommGroup M] [Module R M] [FiniteDimensional R M]
    {k : ℕ} [Invertible (k.factorial : R)]
    (f : Module.End R M) :
    PiTensorProduct.tprod R (fun _ : Fin k => f) ∈
      Algebra.adjoin R
        (Set.range fun g : (M →ₗ[R] M)ˣ =>
          PiTensorProduct.tprod R (fun _ : Fin k => (g : Module.End R M))) := by
  -- Let `e := Module.finBasis R M` and `E := Module.Basis.end e`.
  -- Expand `f` in the basis `E` of `Module.End R M`:
  -- `f = ∑ p : Fin (Module.finrank R M) × Fin (Module.finrank R M), c p • E p`.
  -- Then multilinearity of `PiTensorProduct.tprod` gives an expansion
  -- `PiTensorProduct.tprod R (fun _ : Fin k => f)`
  -- as a finite sum over tuples `w : Fin k → (Fin n × Fin n)` of terms
  -- `(∏ i, c (w i)) • PiTensorProduct.tprod R (fun i => E (w i))`.
  -- Now group this sum by permutation-orbits of tuples `w` under the natural action of `Equiv.Perm (Fin k)` on positions.
  -- Within one orbit, the scalar coefficient `∏ i, c (w i)` is unchanged by permutation, so each orbit contributes a scalar multiple of a basis-end orbit sum of exactly the form handled by
  -- `symmetrized_basisEnd_mem_adjoin_diagonal_units`.
  -- Hence every orbit contribution lies in the adjoin, and therefore so does the whole diagonal pure tensor.
  -- 
  -- Key point: no division by orbit size is needed. We only regroup equal-coefficient terms into orbit sums and apply closure of a subalgebra under finite sums and scalar multiplication.
  -- 
  -- Possible formal routes:
  -- * perform the expansion with repeated `Finset.sum` / multilinearity lemmas for `PiTensorProduct.tprod`, then use a quotient-by-orbits or chosen orbit representatives;
  -- * or prove by induction on `k`, peeling off one tensor factor at a time and invoking `symmetrized_basisEnd_mem_adjoin_diagonal_units` on the resulting orbit sums.
  -- 
  -- Once this node is proved, the general symmetrized theorem should become a short wrapper via the inclusion–exclusion formula.
  sorry

theorem symmetrized_tprod_eq_powerset_diagonal {R : Type*} [CommRing R]
    {A : Type*} [AddCommGroup A] [Module R A]
    {k : ℕ} (f : Fin k → A) :
    (∑ σ : Equiv.Perm (Fin k),
      PiTensorProduct.tprod R (fun i : Fin k => f (σ i))) =
    (((Finset.univ : Finset (Fin k)).powerset).sum fun s =>
      (-1 : R) ^ (k - s.card) •
        PiTensorProduct.tprod R (fun _ : Fin k => s.sum fun i => f i)) := by
  -- This is the clean inclusion–exclusion identity for symmetrized pure tensors.
  -- 
  -- Write
  -- `δ(x) := PiTensorProduct.tprod R (fun _ : Fin k => x)`.
  -- Then the right-hand side is the alternating sum over subsets `s ⊆ Fin k` of `δ (s.sum fun i => f i)`.
  -- Expanding each `δ (s.sum fun i => f i)` by multilinearity gives a sum over all functions `a : Fin k → Fin k`
  -- whose image is contained in `s`, namely the tensor
  -- `PiTensorProduct.tprod R (fun j => f (a j))`.
  -- So the coefficient of a fixed tensor
  -- `PiTensorProduct.tprod R (fun j => f (g j))`
  -- in the whole powerset sum is
  -- `∑_{s ⊇ Finset.image g Finset.univ} (-1)^(k - s.card)`.
  -- By the usual Möbius-inversion / inclusion–exclusion identity on subsets of `Fin k`, this coefficient is:
  -- * `1` if `Set.range g = Set.univ`, equivalently if `g` is surjective,
  -- * `0` otherwise.
  -- Since `g : Fin k → Fin k`, surjective means bijective, so the surviving maps are exactly the permutations.
  -- Hence the right-hand side equals the left-hand side.
  -- 
  -- Suggested formal route:
  -- * expand the right-hand side using multilinearity of `PiTensorProduct.tprod`,
  -- * reorganize the sum with `Finset.powerset`, `Finset.sum_sigma'`, and `Finset.sum_filter`,
  -- * use the subset inclusion–exclusion identity for the final coefficient computation.
  -- 
  -- Important point: there is **no factorial** in this identity; the alternating subset sum already picks out exactly the permutation terms.
  sorry

theorem symmetrized_tprod_mem_adjoin_diagonal_units {R : Type*} [Field R]
    {M : Type*} [AddCommGroup M] [Module R M] [FiniteDimensional R M]
    {k : ℕ} [Invertible (k.factorial : R)]
    (f : Fin k → Module.End R M) :
    (∑ σ : Equiv.Perm (Fin k),
      PiTensorProduct.tprod R (fun i : Fin k => f (σ i))) ∈
      Algebra.adjoin R
        (Set.range fun g : (M →ₗ[R] M)ˣ =>
          PiTensorProduct.tprod R (fun _ : Fin k => (g : Module.End R M))) := by
  rw [symmetrized_tprod_eq_powerset_diagonal (R := R) (A := Module.End R M) f]
  let A : Subalgebra R (PiTensorProduct R (fun _ : Fin k => Module.End R M)) :=
    Algebra.adjoin R
      (Set.range fun g : (M →ₗ[R] M)ˣ =>
        PiTensorProduct.tprod R (fun _ : Fin k => (g : Module.End R M)))
  change (((Finset.univ : Finset (Fin k)).powerset).sum fun s =>
      (-1 : R) ^ (k - s.card) • PiTensorProduct.tprod R (fun _ : Fin k => s.sum fun i => f i)) ∈ A
  refine A.sum_mem ?_
  intro s hs
  show (-1 : R) ^ (k - s.card) • PiTensorProduct.tprod R (fun _ : Fin k => s.sum fun i => f i) ∈ A
  exact A.smul_mem
    (diagonal_tprod_mem_adjoin_diagonal_units (R := R) (M := M) (k := k)
      (f := s.sum fun i => f i))
    ((-1 : R) ^ (k - s.card))

theorem fixed_points_mem_adjoin_diagonal_units {R : Type*} [Field R]
    {M : Type*} [AddCommGroup M] [Module R M] [FiniteDimensional R M]
    {k : ℕ} [Invertible (k.factorial : R)]
    (x : PiTensorProduct R (fun _ : Fin k => Module.End R M))
    (hx : ∀ σ : Equiv.Perm (Fin k),
      PiTensorProduct.reindex R (fun _ : Fin k => Module.End R M) σ x = x) :
    x ∈ Algebra.adjoin R
      (Set.range fun g : (M →ₗ[R] M)ˣ =>
        PiTensorProduct.tprod R (fun _ : Fin k => (g : Module.End R M))) := by
  let diagUnits : Set (PiTensorProduct R (fun _ : Fin k => Module.End R M)) :=
    Set.range fun g : (M →ₗ[R] M)ˣ =>
      PiTensorProduct.tprod R (fun _ : Fin k => (g : Module.End R M))
  let A : PiTensorProduct R (fun _ : Fin k => Module.End R M) →ₗ[R]
      PiTensorProduct R (fun _ : Fin k => Module.End R M) :=
    ∑ σ : Equiv.Perm (Fin k),
      (PiTensorProduct.reindex R (fun _ : Fin k => Module.End R M) σ.symm :
        PiTensorProduct R (fun _ : Fin k => Module.End R M) →ₗ[R]
          PiTensorProduct R (fun _ : Fin k => Module.End R M))
  have hA : ∀ z : PiTensorProduct R (fun _ : Fin k => Module.End R M), A z ∈ Algebra.adjoin R diagUnits := by
    intro z
    refine PiTensorProduct.induction_on z ?_ ?_
    · intro r f
      have hsym :
          (∑ σ : Equiv.Perm (Fin k),
            PiTensorProduct.tprod R (fun i : Fin k => f (σ i))) ∈ Algebra.adjoin R diagUnits := by
        simpa [diagUnits] using
          (symmetrized_tprod_mem_adjoin_diagonal_units (R := R) (M := M) (k := k) f)
      simpa [A, LinearMap.sum_apply, PiTensorProduct.reindex_tprod, Finset.smul_sum] using
        (Algebra.adjoin R diagUnits).smul_mem hsym r
    · intro x y hx hy
      simpa [A, map_add, LinearMap.sum_apply] using (Algebra.adjoin R diagUnits).add_mem hx hy
  have hAx : A x = (k.factorial : R) • x := by
    calc
      A x = ∑ σ : Equiv.Perm (Fin k), x := by
        simp [A, LinearMap.sum_apply, hx]
      _ = (Fintype.card (Equiv.Perm (Fin k)) : R) • x := by
        rw [Nat.cast_smul_eq_nsmul R]
        simp
      _ = (k.factorial : R) • x := by
        rw [Fintype.card_perm, Fintype.card_fin]
  have hmemAx : A x ∈ Algebra.adjoin R diagUnits := hA x
  have hx_eq : x = (⅟ (k.factorial : R)) • A x := by
    rw [hAx]
    simp [smul_smul]
  rw [hx_eq]
  exact (Algebra.adjoin R diagUnits).smul_mem hmemAx _

noncomputable def tensorEndAlgHom (R : Type*) (M : Type*) [CommSemiring R]
    [AddCommMonoid M] [Module R M] (k : ℕ) :
    PiTensorProduct R (fun _ : Fin k => Module.End R M) →ₐ[R] Module.End R (TensorPower R k M) :=
  PiTensorProduct.liftAlgHom
    (R := R) (A := fun _ : Fin k => Module.End R M)
    (S := Module.End R (TensorPower R k M))
    (PiTensorProduct.mapMultilinear R (fun _ : Fin k => M) (fun _ : Fin k => M))
    (by
      change PiTensorProduct.map (fun _ : Fin k => (1 : M →ₗ[R] M)) = 1
      simpa using (PiTensorProduct.map_one (R := R) (s := fun _ : Fin k => M)))
    (by
      intro x y
      change PiTensorProduct.map (fun i : Fin k => x i * y i) = PiTensorProduct.map x * PiTensorProduct.map y
      simpa using (PiTensorProduct.map_mul (R := R) (s := fun _ : Fin k => M) x y))

theorem tensorEndAlgHom_diagonal_eq_glAction {R : Type*} [CommSemiring R]
    {M : Type*} [AddCommMonoid M] [Module R M]
    {k : ℕ} (g : (M →ₗ[R] M)ˣ) :
    tensorEndAlgHom R M k (PiTensorProduct.tprod R (fun _ : Fin k => (g : M →ₗ[R] M))) =
      glAction R M k g := by
  simpa [tensorEndAlgHom, glAction]

theorem tensorEndAlgHom_injective {R : Type*} [Field R]
    {M : Type*} [AddCommGroup M] [Module R M] [FiniteDimensional R M]
    {k : ℕ} :
    Function.Injective (tensorEndAlgHom R M k) := by
  -- Prove injectivity by induction on `k` via an explicit decomposition of `tensorEndAlgHom` into standard linear equivalences.
  -- 
  -- Base case `k = 0`:
  -- * Domain: `PiTensorProduct R (fun _ : Fin 0 => Module.End R M) ≃ₗ[R] R` via `PiTensorProduct.isEmptyEquiv`.
  -- * Codomain: `Module.End R (TensorPower R 0 M) ≃ₐ[R] Module.End R R ≃ₐ[R] R`, using `TensorPower.algebraMap₀` and `AlgEquiv.moduleEndSelf`, then forget to a linear equivalence.
  -- * Check on `PiTensorProduct.tprod` that under these identifications `tensorEndAlgHom R M 0` is the identity map on `R`. Hence it is injective.
  -- 
  -- Inductive step `k -> k+1`:
  -- 1. Domain decomposition:
  --    * Reindex along `finSumFinEquiv.symm` to split `Fin (k+1)` into `Fin 1 ⊕ Fin k`.
  --    * Use `PiTensorProduct.tmulEquiv R (Module.End R M)`.
  --    * Use `PiTensorProduct.subsingletonEquiv (R := R) (s := fun _ : Fin 1 => Module.End R M) 0` to replace the `Fin 1` tensor factor by `Module.End R M`.
  --    This yields a linear equivalence
  --    `eDom : PiTensorProduct R (fun _ : Fin (k+1) => Module.End R M)
  --       ≃ₗ[R] Module.End R M ⊗[R] PiTensorProduct R (fun _ : Fin k => Module.End R M)`.
  -- 
  -- 2. Codomain decomposition:
  --    * Use `TensorPower.mulEquiv (R := R) (M := M) (n := 1) (m := k)`.
  --    * Replace `TensorPower R 1 M` with `M` via `PiTensorProduct.subsingletonEquiv`.
  --    * Conjugate endomorphisms using `LinearEquiv.conjAlgEquiv R`.
  --    This yields
  --    `eCod : Module.End R (TensorPower R (k+1) M)
  --       ≃ₗ[R] Module.End R (M ⊗[R] TensorPower R k M)`.
  -- 
  -- 3. Identify the transported map:
  --    Under `eDom` and `eCod`, `tensorEndAlgHom R M (k+1)` is exactly
  --    the composition of
  --    * `homTensorHomEquiv R M (TensorPower R k M) M (TensorPower R k M)`, and
  --    * the tensor of `LinearMap.id` on the first factor with `(tensorEndAlgHom R M k).toLinearMap` on the second factor.
  --    Verify this on pure tensors using:
  --    * `PiTensorProduct.tmulEquiv_symm_apply`
  --    * `PiTensorProduct.piTensorHomMap_tprod_eq_map`
  --    * `homTensorHomEquiv_apply`
  --    * `tensorEndAlgHom`
  --    and then conclude by extensionality (`PiTensorProduct.ext` / `TensorProduct.ext`).
  -- 
  -- 4. Conclude injectivity:
  --    each of `eDom`, `eCod`, and `homTensorHomEquiv` is injective, and the tensor factor coming from the induction hypothesis is injective, so the whole map is injective.
  -- 
  -- Fallback route:
  -- * choose `b := Module.finBasis R M`, transport both domain and codomain to iterated matrix algebras via `algEquivMatrix b`, `TensorProduct.toMatrix_map`, and Kronecker products, and observe that the resulting map is manifestly injective.
  sorry

theorem tensorEndAlgHom_reindex_tprod_mul_symAction {R : Type*} [CommSemiring R]
    {M : Type*} [AddCommMonoid M] [Module R M]
    {k : ℕ} (σ : Equiv.Perm (Fin k)) (f : Fin k → Module.End R M) :
    tensorEndAlgHom R M k
        (PiTensorProduct.reindex R (fun _ : Fin k => Module.End R M) σ (PiTensorProduct.tprod R f)) *
      symAction R M k σ =
      symAction R M k σ * tensorEndAlgHom R M k (PiTensorProduct.tprod R f) := by
  simpa [tensorEndAlgHom, symAction] using
    (PiTensorProduct.map_comp_reindex_eq
      (R := R) (s := fun _ : Fin k => M) (t := fun _ : Fin k => M) f σ)

theorem tensorEndAlgHom_reindex_mul_symAction {R : Type*} [CommSemiring R]
    {M : Type*} [AddCommMonoid M] [Module R M]
    {k : ℕ} (σ : Equiv.Perm (Fin k))
    (x : PiTensorProduct R (fun _ : Fin k => Module.End R M)) :
    tensorEndAlgHom R M k (PiTensorProduct.reindex R (fun _ : Fin k => Module.End R M) σ x) *
      symAction R M k σ =
      symAction R M k σ * tensorEndAlgHom R M k x := by
  refine PiTensorProduct.induction_on x ?h_smul_tprod ?h_add
  · intro r f
    simpa [smul_mul_assoc, mul_smul_comm] using
      congrArg (fun z => r • z)
        (tensorEndAlgHom_reindex_tprod_mul_symAction (R := R) (M := M) (k := k) σ f)
  · intro x y hx hy
    simp [map_add, hx, hy, add_mul, mul_add]

theorem tensorPower_finrank {R : Type*} [Field R]
    {V : Type*} [AddCommGroup V] [Module R V] [FiniteDimensional R V]
    {k : ℕ} :
    Module.finrank R (TensorPower R k V) = (Module.finrank R V) ^ k := by
  induction k with
  | zero =>
      simpa using (LinearEquiv.finrank_eq (TensorPower.algebraMap₀ (R := R) (M := V))).symm
  | succ k ih =>
      rw [← LinearEquiv.finrank_eq (TensorPower.mulEquiv (R := R) (M := V) (n := k) (m := 1))]
      rw [Module.finrank_tensorProduct]
      rw [ih]
      rw [← LinearEquiv.finrank_eq (PiTensorProduct.subsingletonEquiv (R := R) (s := fun _ : Fin 1 => V) 0)]
      simp [pow_succ]

theorem tensorEndAlgHom_bijective {R : Type*} [Field R]
    {M : Type*} [AddCommGroup M] [Module R M] [FiniteDimensional R M]
    {k : ℕ} :
    Function.Bijective (tensorEndAlgHom R M k) := by
  have hTensor : ∀ n : ℕ, FiniteDimensional R (TensorPower R n M) := by
    intro n
    induction n with
    | zero =>
        exact (PiTensorProduct.isEmptyEquiv (R := R) (s := fun _ : Fin 0 => M)).symm.finiteDimensional
    | succ n ih =>
        let e1 : TensorPower R 1 M ≃ₗ[R] M :=
          PiTensorProduct.subsingletonEquiv (R := R) (s := fun _ : Fin 1 => M) 0
        haveI : FiniteDimensional R (TensorPower R n M) := ih
        haveI : FiniteDimensional R (TensorPower R 1 M) := e1.symm.finiteDimensional
        haveI : FiniteDimensional R (TensorProduct R (TensorPower R n M) (TensorPower R 1 M)) :=
          Module.Finite.tensorProduct R (TensorPower R n M) (TensorPower R 1 M)
        exact (TensorPower.mulEquiv (R := R) (M := M) (n := n) (m := 1)).finiteDimensional
  letI : FiniteDimensional R (TensorPower R k M) := hTensor k
  letI : FiniteDimensional R (Module.End R (TensorPower R k M)) := LinearMap.finiteDimensional
  have hinj : Function.Injective ((tensorEndAlgHom R M k).toLinearMap) :=
    tensorEndAlgHom_injective (R := R) (M := M) (k := k)
  have hfin :
      Module.finrank R (PiTensorProduct R (fun _ : Fin k => Module.End R M)) =
        Module.finrank R (Module.End R (TensorPower R k M)) := by
    change Module.finrank R (TensorPower R k (Module.End R M)) =
      Module.finrank R (Module.End R (TensorPower R k M))
    rw [tensorPower_finrank (R := R) (V := Module.End R M) (k := k)]
    rw [Module.finrank_linearMap]
    rw [Module.finrank_linearMap]
    simp_rw [tensorPower_finrank (R := R) (V := M) (k := k)]
    rw [← pow_two (Module.finrank R M)]
    rw [← pow_mul]
    rw [← pow_two (Module.finrank R M ^ k)]
    rw [← pow_mul]
    simpa [Nat.mul_comm]
  let e := LinearEquiv.ofInjectiveOfFinrankEq ((tensorEndAlgHom R M k).toLinearMap) hinj hfin
  refine ⟨tensorEndAlgHom_injective (R := R) (M := M) (k := k), ?_⟩
  simpa using e.surjective

theorem tensorEndAlgHom_mem_centralizer_iff_fixed {R : Type*} [Field R]
    {M : Type*} [AddCommGroup M] [Module R M] [FiniteDimensional R M]
    {k : ℕ} (x : PiTensorProduct R (fun _ : Fin k => Module.End R M)) :
    tensorEndAlgHom R M k x ∈
        Subalgebra.centralizer R (Set.range (symAction R M k)) ↔
      ∀ σ : Equiv.Perm (Fin k),
        PiTensorProduct.reindex R (fun _ : Fin k => Module.End R M) σ x = x := by
  let Φ := tensorEndAlgHom R M k
  constructor
  · intro hx σ
    rw [Subalgebra.mem_centralizer_iff] at hx
    have hcomm : symAction R M k σ * Φ x = Φ x * symAction R M k σ :=
      hx (symAction R M k σ) ⟨σ, rfl⟩
    have hreindex :
        Φ (PiTensorProduct.reindex R (fun _ : Fin k => Module.End R M) σ x) *
            symAction R M k σ =
          Φ x * symAction R M k σ := by
      calc
        Φ (PiTensorProduct.reindex R (fun _ : Fin k => Module.End R M) σ x) *
            symAction R M k σ =
          symAction R M k σ * Φ x := by
            simpa only [Φ] using
              tensorEndAlgHom_reindex_mul_symAction (R := R) (M := M) (k := k) σ x
        _ = Φ x * symAction R M k σ := hcomm
    have hreindex' := congrArg (fun y => y * symAction R M k σ⁻¹) hreindex
    have hσ : symAction R M k σ * symAction R M k σ⁻¹ = 1 := by
      calc
        symAction R M k σ * symAction R M k σ⁻¹ = symAction R M k (σ * σ⁻¹) := by
          exact ((symAction R M k).map_mul σ σ⁻¹).symm
        _ = symAction R M k 1 := by rw [mul_inv_cancel]
        _ = 1 := (symAction R M k).map_one
    have hΦinj : Function.Injective (tensorEndAlgHom R M k) :=
      (tensorEndAlgHom_bijective (R := R) (M := M) (k := k)).1
    apply hΦinj
    simpa only [Φ, mul_assoc, hσ, mul_one] using hreindex'
  · intro hx
    rw [Subalgebra.mem_centralizer_iff]
    intro y hy
    rcases hy with ⟨σ, rfl⟩
    have h :=
      tensorEndAlgHom_reindex_mul_symAction (R := R) (M := M) (k := k) σ x
    simpa only [hx σ] using h.symm

theorem glAction_range_eq_centralizer_symAction {R : Type*} [Field R]
    {M : Type*} [AddCommGroup M] [Module R M] [FiniteDimensional R M]
    {k : ℕ} [Invertible (k.factorial : R)] :
    Algebra.adjoin R (Set.range (glAction R M k)) =
      Subalgebra.centralizer R (Set.range (symAction R M k)) := by
  classical
  let Φ := tensorEndAlgHom R M k
  let diagSet : Set (PiTensorProduct R (fun _ : Fin k => Module.End R M)) :=
    Set.range fun g : (M →ₗ[R] M)ˣ =>
      PiTensorProduct.tprod R (fun _ : Fin k => (g : Module.End R M))
  apply le_antisymm
  · exact glAction_adjoin_le_centralizer_symAction (R := R) (M := M) (k := k)
  · intro y hy
    rcases (tensorEndAlgHom_bijective (R := R) (M := M) (k := k)).surjective y with ⟨x, rfl⟩
    have hxfixed : ∀ σ : Equiv.Perm (Fin k),
        PiTensorProduct.reindex R (fun _ : Fin k => Module.End R M) σ x = x := by
      exact (tensorEndAlgHom_mem_centralizer_iff_fixed (R := R) (M := M) (k := k) x).mp hy
    have hxadjoin : x ∈ Algebra.adjoin R diagSet := by
      simpa [diagSet] using
        fixed_points_mem_adjoin_diagonal_units (R := R) (M := M) (k := k) x hxfixed
    have hmap : Φ x ∈ (Algebra.adjoin R diagSet).map Φ := by
      exact ⟨x, hxadjoin, rfl⟩
    rw [AlgHom.map_adjoin] at hmap
    have himage : Φ '' diagSet = Set.range (glAction R M k) := by
      ext z
      constructor
      · rintro ⟨w, ⟨g, rfl⟩, rfl⟩
        exact ⟨g, (tensorEndAlgHom_diagonal_eq_glAction (R := R) (M := M) (k := k) g).symm⟩
      · rintro ⟨g, rfl⟩
        exact ⟨PiTensorProduct.tprod R (fun _ : Fin k => (g : Module.End R M)), ⟨g, rfl⟩,
          tensorEndAlgHom_diagonal_eq_glAction (R := R) (M := M) (k := k) g⟩
    simpa [himage, diagSet] using hmap


